---
import type { WhyCiConData } from '../lib/types';
interface Props { data: WhyCiConData }
const { data } = Astro.props;
---

<section id="why-cicon" class="py-20 lg:py-28 bg-white">
  <div class="container-xl">

    <div class="text-center mb-16">
      <span class="section-label">Trusted Since 2010</span>
      <h2 class="section-heading mx-auto max-w-3xl">{data.headline}</h2>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      {data.stats.map((stat) => (
        <div class="relative text-center p-8 rounded-2xl bg-gradient-to-br from-navy-800 to-navy-900 overflow-hidden group">
          <!-- Glow -->
          <div class="absolute inset-0 bg-teal-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10">
            <div class="text-5xl md:text-6xl font-black text-teal-400 mb-2 tabular-nums">
              {stat.value}
            </div>
            <div class="text-base font-medium text-gray-300 uppercase tracking-wider">
              {stat.label}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Description + visual layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          {data.description}
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/book-a-strategy-call-with-cicon-marketing/"
            class="btn-primary"
          >
            Work With Us
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Feature checklist -->
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
        <h3 class="text-lg font-bold text-navy-800 mb-6">What Sets Us Apart</h3>
        <ul class="space-y-4">
          {[
            'Boutique agency — you work with the actual strategists, not account managers',
            'Full-funnel approach from awareness to conversion to retention',
            'Transparent, jargon-free reporting every month',
            'Local GTA market expertise with hyper-targeted campaigns',
            'No long-term contracts — we earn your business every month',
          ].map((item) => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-teal-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-teal-700" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span class="text-gray-700 leading-snug">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>
</section>
