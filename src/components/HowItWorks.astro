---
import type { HowItWorksData } from '../lib/types';
interface Props { data: HowItWorksData }
const { data } = Astro.props;
---

<section id="how-it-works" class="py-20 lg:py-28 bg-navy-900 relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-hero-pattern"></div>
  <div class="absolute top-0 left-1/2 w-[800px] h-[800px] bg-teal-600/8 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

  <div class="container-xl relative z-10">

    <div class="text-center mb-16">
      <span class="inline-block text-teal-400 font-semibold text-sm tracking-widest uppercase mb-3">
        Our Process
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">
        {data.headline}
      </h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
        {data.subheadline}
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 relative">

      {/* Connector line – desktop only */}
      <div class="hidden lg:block absolute top-[56px] left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-teal-700 to-transparent z-0"></div>

      {data.steps.map((step, i) => (
        <div class="relative group bg-white/5 hover:bg-white/10 border border-white/10 hover:border-teal-600/40 rounded-2xl p-7 transition-all duration-300 z-10">
          <!-- Step number badge -->
          <div class="w-14 h-14 rounded-2xl bg-navy-800 border-2 border-teal-600/40 group-hover:border-teal-500 group-hover:bg-teal-600 flex items-center justify-center mb-6 transition-all duration-300">
            <span class="text-xl font-black text-teal-400 group-hover:text-white transition-colors duration-300 tabular-nums">
              {step.stepNumber}
            </span>
          </div>

          <!-- Arrow connector – visible between cards on desktop -->
          {i < data.steps.length - 1 && (
            <div class="hidden lg:flex absolute -right-3 top-[56px] -translate-y-1/2 z-20">
              <div class="w-6 h-6 rounded-full bg-teal-600 flex items-center justify-center shadow-lg shadow-teal-900/50">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          )}

          <h3 class="text-lg font-bold text-white mb-3">{step.title}</h3>
          <p class="text-sm text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 text-center">
      <a href="/book-a-strategy-call-with-cicon-marketing/"
         class="inline-flex items-center gap-2.5 px-8 py-4 bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg rounded-xl transition-all duration-200 shadow-xl shadow-teal-900/40 hover:shadow-teal-600/30 hover:-translate-y-0.5">
        Start Your Journey
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
