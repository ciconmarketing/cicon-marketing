---
import type { HowItWorksData } from '../lib/types';
import ProcessSteps from './react/ProcessSteps.tsx';
interface Props { data: HowItWorksData }
const { data } = Astro.props;
---

<section id="how-it-works" class="py-20 lg:py-28 bg-navy-900 relative overflow-hidden">
  <div class="absolute inset-0" style="background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 40px 40px;"></div>
  <div class="absolute top-0 left-1/2 w-[800px] h-[800px] bg-teal-600/8 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>

  <div class="container-xl relative z-10">

    <div class="text-center mb-16">
      <span class="inline-block text-teal-400 font-semibold text-sm tracking-widest uppercase mb-3" data-aos="fade-up">
        Our Process
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4" data-aos="fade-up" data-aos-delay="100">
        {data.headline}
      </h2>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed" data-aos="fade-up" data-aos-delay="200">
        {data.subheadline}
      </p>
    </div>

    <ProcessSteps steps={data.steps} client:visible />

    <div class="mt-14 text-center" data-aos="zoom-in-up" data-aos-delay="100">
      <a href="/book-a-strategy-call-with-cicon-marketing/"
         class="inline-flex items-center gap-2.5 px-8 py-4 bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg rounded-xl transition-all duration-200 shadow-xl hover:-translate-y-0.5">
        Start Your Journey
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
