---
import type { ServicesData } from '../lib/types';
import ServiceCards from './react/ServiceCards.tsx';
interface Props { data: ServicesData }
const { data } = Astro.props;
---

<section id="services" class="py-20 lg:py-28 bg-gray-50">
  <div class="container-xl">

    <div class="text-center mb-14">
      <span class="section-label" data-aos="fade-up">Our Expertise</span>
      <h2 class="section-heading" data-aos="fade-up" data-aos-delay="100">{data.headline}</h2>
      <p class="section-subheading mx-auto mt-4" data-aos="fade-up" data-aos-delay="200">
        End-to-end digital marketing solutions built to generate leads, grow revenue, and dominate your local market.
      </p>
    </div>

    <ServiceCards items={data.items} client:visible />

    <!-- Bottom CTA -->
    <div class="mt-14 text-center" data-aos="fade-up">
      <p class="text-gray-500 mb-6">Not sure which services are right for you?</p>
      <a href="/book-a-strategy-call-with-cicon-marketing/" class="btn-primary">
        Get a Free Marketing Audit
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
