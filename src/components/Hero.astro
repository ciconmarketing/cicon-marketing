---
import type { HeroData } from '../lib/types';
interface Props { data: HeroData }
const { data } = Astro.props;
---

<section
  id="hero"
  class="relative min-h-screen flex items-center bg-navy-900 overflow-hidden pt-20"
>
  <!-- Background gradient layers -->
  <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900"></div>
  <!-- Radial accent glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-teal-600/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-teal-600/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>
  <!-- Dot grid pattern -->
  <div
    class="absolute inset-0 opacity-30"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px); background-size: 40px 40px;"
  ></div>

  <div class="container-xl relative z-10 py-20 lg:py-28">
    <div class="max-w-4xl">

      <!-- Location badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full text-sm text-teal-300 font-medium mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Richmond Hill &amp; GTA, Ontario
      </div>

      <!-- Main headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.08] mb-7 tracking-tight">
        {data.headline.split('Richmond Hill').map((part, i, arr) => (
          i < arr.length - 1
            ? <>{part}<span class="text-teal-400">Richmond Hill</span></>
            : part
        ))}
      </h1>

      <!-- Subheadline -->
      <p class="text-xl md:text-2xl text-gray-300 leading-relaxed mb-10 max-w-3xl">
        {data.subheadline}
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={data.ctaLink}
          class="inline-flex items-center justify-center gap-2.5 px-8 py-4 bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg rounded-xl transition-all duration-200 shadow-2xl shadow-teal-900/50 hover:shadow-teal-600/40 hover:-translate-y-0.5 active:translate-y-0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {data.ctaText}
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/25 text-white font-semibold text-lg rounded-xl hover:border-white/50 hover:bg-white/5 transition-all duration-200 hover:-translate-y-0.5"
        >
          See Our Services
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>

      <!-- Trust micro-copy -->
      <p class="mt-6 text-sm text-gray-400">
        Free consultation &middot; No long-term lock-in &middot; Results you can actually measure
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-400 text-xs">
    <span class="tracking-widest uppercase">Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-gray-400 to-transparent"></div>
  </div>
</section>
