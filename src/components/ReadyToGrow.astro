---
import type { ReadyToGrowData } from '../lib/types';
interface Props { data: ReadyToGrowData }
const { data } = Astro.props;
---

<section id="ready-to-grow" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background image with slow-pan animation -->
  <div class="absolute inset-0 overflow-hidden">
    <img
      src={data.backgroundImageUrl ?? "https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1920&q=75&auto=format&fit=crop"}
      alt={data.backgroundImageAlt ?? "Team meeting"}
      class="w-full h-full object-cover slow-pan"
    />
    <div class="absolute inset-0 bg-navy-900/95"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900/40 via-transparent to-teal-900/40"></div>
  </div>

  <div class="container-xl relative z-10 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-teal-600/20 border border-teal-500/30 text-teal-300 text-sm font-medium mb-8" data-aos="zoom-in-up">
      <span class="w-2 h-2 rounded-full animate-pulse" style="background:#ffcf00"></span>
      Now Accepting New Clients
    </div>

    <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 max-w-3xl mx-auto" data-aos="fade-up" data-aos-delay="100">
      {data.headline}
    </h2>

    <p class="text-xl text-gray-300 leading-relaxed max-w-2xl mx-auto mb-10" data-aos="fade-up" data-aos-delay="200">
      {data.subheadline}
    </p>

    <div class="flex flex-col sm:flex-row flex-wrap gap-4 justify-center items-center" data-aos="fade-up" data-aos-delay="300">
      <!-- Primary CTA -->
      <a
        href={data.ctaLink}
        class="inline-flex items-center gap-2.5 px-9 py-4 bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg rounded-xl transition-all duration-200 shadow-2xl hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {data.ctaText}
      </a>

      <!-- Send message link -->
      <a href="#contact" class="inline-flex items-center gap-2 text-gray-300 hover:text-white font-medium transition-colors duration-150">
        Or send us a message
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <!-- WhatsApp CTA -->
      <a
        href="https://wa.me/message/ZOH7PUBSFSN4N1"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-7 py-4 font-semibold text-lg rounded-xl transition-all duration-200 hover:-translate-y-0.5 text-white"
        style="background:rgba(37,211,102,0.18);border:1.5px solid rgba(37,211,102,0.4)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat on WhatsApp
      </a>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-gray-400" data-aos="fade-up" data-aos-delay="400">
      {['100% Free Consultation', 'No Contracts Required', 'Results-Driven Strategy', '15+ Years of Experience'].map(item => (
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
