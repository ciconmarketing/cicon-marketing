---
import type { ReadyToGrowData } from '../lib/types';
interface Props { data: ReadyToGrowData }
const { data } = Astro.props;
---

<section id="ready-to-grow" class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=1920&q=75&auto=format&fit=crop"
      alt="Team meeting"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-navy-900/95"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900/40 via-transparent to-teal-900/40"></div>
  </div>

  <div class="container-xl relative z-10 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-teal-600/20 border border-teal-500/30 text-teal-300 text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full animate-pulse" style="background:#ffcf00"></span>
      Now Accepting New Clients
    </div>

    <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 max-w-3xl mx-auto">
      {data.headline}
    </h2>

    <p class="text-xl text-gray-300 leading-relaxed max-w-2xl mx-auto mb-10">
      {data.subheadline}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href={data.ctaLink}
        class="inline-flex items-center gap-2.5 px-9 py-4 bg-teal-600 hover:bg-teal-500 text-white font-bold text-lg rounded-xl transition-all duration-200 shadow-2xl hover:-translate-y-0.5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {data.ctaText}
      </a>
      <a href="#contact" class="inline-flex items-center gap-2 text-gray-300 hover:text-white font-medium transition-colors duration-150">
        Or send us a message
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-gray-400">
      {['100% Free Consultation', 'No Contracts Required', 'Results-Driven Strategy', '14+ Years of Experience'].map(item => (
        <span class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          {item}
        </span>
      ))}
    </div>
  </div>
</section>
