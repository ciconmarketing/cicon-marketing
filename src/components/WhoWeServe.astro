---
import type { WhoWeServeData } from '../lib/types';
interface Props { data: WhoWeServeData }
const { data } = Astro.props;

const icons: Record<string, string> = {
  tooth: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
  home: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>`,
  store: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`,
  briefcase: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
};

const fallbackIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`;

// Accent colors per card (cycles)
const accents = ['teal', 'blue', 'indigo', 'cyan'];
---

<section id="who-we-serve" class="py-20 lg:py-28 bg-white">
  <div class="container-xl">

    <div class="text-center mb-14">
      <span class="section-label">Industries We Serve</span>
      <h2 class="section-heading">{data.headline}</h2>
      <p class="section-subheading mx-auto mt-4">{data.subheadline}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {data.industries.map((industry) => (
        <div class="relative group rounded-2xl overflow-hidden border border-gray-100 bg-white shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
          <!-- Top accent bar -->
          <div class="h-1.5 bg-gradient-to-r from-teal-500 to-teal-400"></div>

          <div class="p-7">
            <!-- Icon circle -->
            <div class="w-14 h-14 rounded-2xl bg-navy-800 flex items-center justify-center mb-5 group-hover:bg-teal-600 transition-colors duration-250">
              <div class="w-7 h-7 text-teal-400 group-hover:text-white transition-colors duration-250"
                   set:html={icons[industry.icon] ?? fallbackIcon}
              />
            </div>

            <h3 class="text-lg font-bold text-navy-800 mb-3">{industry.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{industry.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA strip -->
    <div class="mt-14 bg-gray-50 rounded-2xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6 border border-gray-100">
      <div>
        <h3 class="text-xl font-bold text-navy-800 mb-1">Don't see your industry?</h3>
        <p class="text-gray-500">We work with any growth-focused local business in the GTA. Let's talk.</p>
      </div>
      <a href="/book-a-strategy-call-with-cicon-marketing/" class="btn-primary whitespace-nowrap">
        Book a Free Call
      </a>
    </div>

  </div>
</section>
